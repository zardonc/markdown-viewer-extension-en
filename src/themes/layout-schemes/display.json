{
  "id": "display",
  "name": "展示",
  "name_en": "Display",
  "description": "大字号与宽阔留白，适合演示、封面与重点展示",
  "description_en": "Large type and generous whitespace for showcases and keynotes",
  
  "body": {
    "fontSize": "14pt",
    "lineHeight": 1.8
  },
  
  "headings": {
    "h1": { "fontSize": "36pt", "spacingBefore": "0pt", "spacingAfter": "18pt", "alignment": "left" },
    "h2": { "fontSize": "28pt", "spacingBefore": "28pt", "spacingAfter": "12pt" },
    "h3": { "fontSize": "22pt", "spacingBefore": "20pt", "spacingAfter": "10pt" },
    "h4": { "fontSize": "18pt", "spacingBefore": "16pt", "spacingAfter": "8pt" },
    "h5": { "fontSize": "16pt", "spacingBefore": "12pt", "spacingAfter": "6pt" },
    "h6": { "fontSize": "14pt", "spacingBefore": "10pt", "spacingAfter": "5pt" }
  },
  
  "code": {
    "fontSize": "12pt"
  },
  
  "blocks": {
    "paragraph": { "spacingAfter": "14pt" },
    "list": { "spacingAfter": "16pt" },
    "listItem": { "spacingAfter": "4pt" },
    "blockquote": {
      "spacingBefore": "16pt",
      "spacingAfter": "16pt",
      "paddingVertical": "6pt",
      "paddingHorizontal": "20pt"
    },
    "codeBlock": { "spacingAfter": "16pt" },
    "table": { "spacingAfter": "16pt" },
    "horizontalRule": { "spacingBefore": "28pt", "spacingAfter": "28pt" }
  }
}
