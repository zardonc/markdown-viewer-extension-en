{
  "id": "regular",
  "name": "标准",
  "name_en": "Regular",
  "description": "均衡的标准布局，适合日常写作与多数文档",
  "description_en": "Balanced default layout for everyday writing",
  
  "body": {
    "fontSize": "12pt",
    "lineHeight": 1.7
  },
  
  "headings": {
    "h1": { "fontSize": "26pt", "spacingBefore": "0pt", "spacingAfter": "14pt" },
    "h2": { "fontSize": "21pt", "spacingBefore": "20pt", "spacingAfter": "10pt" },
    "h3": { "fontSize": "17pt", "spacingBefore": "16pt", "spacingAfter": "8pt" },
    "h4": { "fontSize": "14pt", "spacingBefore": "12pt", "spacingAfter": "6pt" },
    "h5": { "fontSize": "13pt", "spacingBefore": "10pt", "spacingAfter": "5pt" },
    "h6": { "fontSize": "12pt", "spacingBefore": "8pt", "spacingAfter": "4pt" }
  },
  
  "code": {
    "fontSize": "11pt"
  },
  
  "blocks": {
    "paragraph": { "spacingAfter": "10pt" },
    "list": { "spacingAfter": "12pt" },
    "listItem": { "spacingAfter": "3pt" },
    "blockquote": {
      "spacingBefore": "12pt",
      "spacingAfter": "12pt",
      "paddingVertical": "2pt",
      "paddingHorizontal": "14pt"
    },
    "codeBlock": { "spacingAfter": "12pt" },
    "table": { "spacingAfter": "12pt" },
    "horizontalRule": { "spacingBefore": "20pt", "spacingAfter": "20pt" }
  }
}
