{
  "id": "editorial",
  "name": "编辑",
  "name_en": "Editorial",
  "description": "强烈的层级感，h2 下划线、h3 侧竖线，适合专栏与长文",
  "description_en": "Strong hierarchy with h2 underline and h3 side rule for features and long reads",
  
  "body": {
    "fontSize": "13pt",
    "lineHeight": 1.75
  },
  
  "headings": {
    "h1": { "fontSize": "32pt", "spacingBefore": "0pt", "spacingAfter": "16pt" },
    "h2": { "fontSize": "24pt", "spacingBefore": "24pt", "spacingAfter": "10pt" },
    "h3": { "fontSize": "19pt", "spacingBefore": "18pt", "spacingAfter": "8pt" },
    "h4": { "fontSize": "16pt", "spacingBefore": "14pt", "spacingAfter": "6pt" },
    "h5": { "fontSize": "14pt", "spacingBefore": "10pt", "spacingAfter": "5pt" },
    "h6": { "fontSize": "13pt", "spacingBefore": "8pt", "spacingAfter": "4pt" }
  },
  
  "code": {
    "fontSize": "11pt"
  },
  
  "blocks": {
    "paragraph": { "spacingAfter": "12pt" },
    "list": { "spacingAfter": "14pt" },
    "listItem": { "spacingAfter": "4pt" },
    "blockquote": {
      "spacingBefore": "14pt",
      "spacingAfter": "14pt",
      "paddingVertical": "4pt",
      "paddingHorizontal": "18pt"
    },
    "codeBlock": { "spacingAfter": "14pt" },
    "table": { "spacingAfter": "14pt" },
    "horizontalRule": { "spacingBefore": "24pt", "spacingAfter": "24pt" }
  }
}
