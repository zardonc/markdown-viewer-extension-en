{
  "name": "markdown-viewer-extension",
  "displayName": "Markdown Viewer Extension",
  "version": "3.2.1",
  "description": "Markdown to perfect Word in one click — PlantUML, Mermaid, Vega, drawio, canvas, Infographic, Graphviz, LaTeX (editable), code highlighting, local processing.",
  "type": "module",
  "scripts": {
    "build:chrome": "node chrome/build.js",
    "build:firefox": "node firefox/build.js",
    "build:mobile": "node mobile/build.js",
    "build:slidev": "cd slidev-shell && npx vite build --config vite.vscode.config.ts",
    "build:vscode": "node vscode/build.js",
    "build:obsidian": "node obsidian/build.js",
    "sync:formats": "node scripts/sync-formats.js",
    "build:app": "node mobile/build-app.js all",
    "build:ios": "node mobile/build-app.js ios",
    "build:ios:sim": "node mobile/build-app.js ios:sim",
    "build:android": "node mobile/build-app.js android",
    "build:macos": "node mobile/build-app.js macos",
    "app:init": "cd mobile && flutter pub get",
    "typecheck": "npx tsc --noEmit"
  },
  "keywords": [
    "markdown",
    "viewer",
    "chrome-extension",
    "syntax-highlighting",
    "mermaid",
    "plantuml",
    "katex",
    "math-formulas",
    "code-highlighting",
    "markdown-to-png",
    "svg-to-png",
    "github-flavored-markdown",
    "gfm",
    "markdown-parser",
    "unified",
    "remark",
    "rehype",
    "office-integration",
    "document-viewer",
    "technical-documentation",
    "chrome-manifest-v3"
  ],
  "author": {
    "name": "Markdown Viewer Team",
    "url": "https://github.com/markdown-viewer"
  },
  "license": "GPL-3.0-only",
  "homepage": "https://docu.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/markdown-viewer/markdown-viewer-extension.git"
  },
  "bugs": {
    "url": "https://github.com/markdown-viewer/markdown-viewer-extension/issues"
  },
  "dependencies": {
    "@antv/infographic": "^0.2.18",
    "@markdown-viewer/draw-uml": "^1.2.0",
    "@markdown-viewer/drawio2svg": "^1.5.1",
    "@mozilla/readability": "^0.6.0",
    "@shikijs/core": "^4.0.2",
    "@shikijs/engine-javascript": "^4.0.2",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/markdown-it": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@slidev/parser": "^52.14.1",
    "@trbn/jsoncanvas": "^1.0.6",
    "@types/markdown-it": "^14.1.2",
    "@viz-js/viz": "^3.24.0",
    "buffer": "^6.0.3",
    "d3-array": "^3.2.4",
    "docx": "^9.5.1",
    "esbuild": "^0.25.12",
    "eventemitter3": "^5.0.1",
    "file-type": "^20.5.0",
    "katex": "^0.16.27",
    "markdown-it": "^14.1.1",
    "markdownlint": "^0.40.0",
    "mathjax-full": "^3.2.2",
    "mermaid": "^11.12.2",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-breaks": "^4.0.0",
    "remark-cjk-friendly": "^1.2.3",
    "remark-gemoji": "^8.0.0",
    "remark-gfm": "^4.0.1",
    "remark-github-blockquote-alert": "^2.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "roughjs": "^4.6.6",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "vega": "^6.2.0",
    "vega-embed": "^7.1.0",
    "vega-interpreter": "^2.2.1",
    "vega-lite": "^6.4.1",
    "xml-js": "^1.6.11"
  },
  "devDependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.26.0",
    "@anthropic-ai/sdk": "^0.71.2",
    "@types/chrome": "^0.1.32",
    "@types/node": "^25.0.3",
    "@types/turndown": "^5.0.6",
    "@types/vscode": "^1.107.0",
    "@vscode/vsce": "^3.7.1",
    "knip": "^5.80.0",
    "material-icon-theme": "^5.33.1",
    "typescript": "^5.9.3",
    "webextension-polyfill": "^0.12.0"
  },
  "publisher": "xicilion",
  "categories": [
    "Visualization",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onLanguage:markdown",
    "onLanguage:mermaid",
    "onLanguage:plantuml",
    "onLanguage:vega",
    "onLanguage:graphviz",
    "onLanguage:infographic",
    "onLanguage:canvas",
    "onLanguage:drawio",
    "onLanguage:xml"
  ],
  "contributes": {
    "languages": [
      {
        "id": "markdown",
        "aliases": [
          "Slidev",
          "slidev"
        ],
        "extensions": [
          ".slides.md"
        ]
      },
      {
        "id": "mermaid",
        "aliases": [
          "Mermaid",
          "mermaid"
        ],
        "extensions": [
          ".mermaid",
          ".mmd"
        ]
      },
      {
        "id": "plantuml",
        "aliases": [
          "Plantuml",
          "plantuml"
        ],
        "extensions": [
          ".plantuml",
          ".puml"
        ]
      },
      {
        "id": "vega",
        "aliases": [
          "Vega",
          "vega",
          "Vega-Lite",
          "vega-lite"
        ],
        "extensions": [
          ".vega",
          ".vl",
          ".vega-lite"
        ]
      },
      {
        "id": "graphviz",
        "aliases": [
          "Dot",
          "dot"
        ],
        "extensions": [
          ".gv",
          ".dot"
        ]
      },
      {
        "id": "infographic",
        "aliases": [
          "Infographic",
          "infographic"
        ],
        "extensions": [
          ".infographic"
        ]
      },
      {
        "id": "canvas",
        "aliases": [
          "Canvas",
          "canvas"
        ],
        "extensions": [
          ".canvas"
        ]
      },
      {
        "id": "drawio",
        "aliases": [
          "Drawio",
          "drawio"
        ],
        "extensions": [
          ".drawio"
        ]
      }
    ],
    "submenus": [
      {
        "id": "markdownViewer.toolsMenu",
        "label": "%toolsMenu.label%",
        "icon": "$(tools)"
      },
      {
        "id": "markdownViewer.exportMenu",
        "label": "Export",
        "icon": "$(save-as)"
      }
    ],
    "commands": [
      {
        "command": "markdownViewer.preview",
        "title": "Open Markdown Preview (Advanced)",
        "category": "Markdown Viewer",
        "icon": "$(go-to-file)"
      },
      {
        "command": "markdownViewer.previewToSide",
        "title": "Open Markdown Preview to the Side (Advanced)",
        "category": "Markdown Viewer",
        "icon": "$(go-to-file)"
      },
      {
        "command": "markdownViewer.exportDocx",
        "title": "Export to DOCX",
        "category": "Markdown Viewer",
        "icon": "$(save-as)"
      },
      {
        "command": "markdownViewer.exportHtml",
        "title": "Export to HTML",
        "category": "Markdown Viewer",
        "icon": "$(file-code)"
      },
      {
        "command": "markdownViewer.openSettings",
        "title": "Open Settings",
        "category": "Markdown Viewer",
        "icon": "$(gear)"
      },
      {
        "command": "markdownViewer.print",
        "title": "Print",
        "category": "Markdown Viewer",
        "icon": "$(print)"
      },
      {
        "command": "markdownViewer.openExportMenu",
        "title": "Open Export Menu",
        "category": "Markdown Viewer",
        "icon": "$(save-as)"
      },
      {
        "command": "markdownViewer.refresh",
        "title": "Refresh Preview",
        "category": "Markdown Viewer",
        "icon": "$(refresh)"
      },
      {
        "command": "markdownViewer.tools.numberHeadings",
        "title": "%command.numberHeadings.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.removeHeadingNumbers",
        "title": "%command.removeHeadingNumbers.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixAll",
        "title": "%command.fixAll.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixWhitespace",
        "title": "%command.fixWhitespace.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixHeadings",
        "title": "%command.fixHeadings.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixLists",
        "title": "%command.fixLists.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixCode",
        "title": "%command.fixCode.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixLinks",
        "title": "%command.fixLinks.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixEmphasis",
        "title": "%command.fixEmphasis.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixTables",
        "title": "%command.fixTables.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixBlockquotes",
        "title": "%command.fixBlockquotes.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.fixProperNames",
        "title": "%command.fixProperNames.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.showDiagnostics",
        "title": "%command.showDiagnostics.title%",
        "category": "%category.markdownTools%"
      },
      {
        "command": "markdownViewer.tools.openSettings",
        "title": "%command.openSettings.title%",
        "category": "%category.markdownTools%",
        "icon": "$(gear)"
      },
      {
        "command": "markdownViewer.toggleTOC",
        "title": "Toggle Table of Contents",
        "category": "Markdown Viewer",
        "icon": "$(list-flat)"
      }
    ],
    "menus": {
      "markdownViewer.toolsMenu": [
        {
          "command": "markdownViewer.tools.numberHeadings"
        },
        {
          "command": "markdownViewer.tools.removeHeadingNumbers"
        },
        {
          "command": "markdownViewer.tools.fixAll",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixWhitespace",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixHeadings",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixLists",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixCode",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixLinks",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixEmphasis",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixTables",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixBlockquotes",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.fixProperNames",
          "group": "fix"
        },
        {
          "command": "markdownViewer.tools.showDiagnostics",
          "group": "diagnostics"
        },
        {
          "command": "markdownViewer.tools.openSettings"
        }
      ],
      "editor/title": [
        {
          "submenu": "markdownViewer.toolsMenu",
          "when": "editorLangId == markdown || resourceExtname == .md",
          "group": "navigation@0"
        },
        {
          "command": "markdownViewer.previewToSide",
          "when": "editorLangId == markdown || editorLangId == mermaid || editorLangId == vega || editorLangId == graphviz || editorLangId == infographic || editorLangId == canvas || editorLangId == drawio || resourceExtname == .md",
          "group": "navigation"
        },
        {
          "command": "markdownViewer.openExportMenu",
          "when": "activeWebviewPanelId == markdownViewerAdvanced",
          "group": "navigation@1"
        },
        {
          "command": "markdownViewer.toggleTOC",
          "when": "activeWebviewPanelId == markdownViewerAdvanced",
          "group": "navigation@1"
        },
        {
          "command": "markdownViewer.openSettings",
          "when": "activeWebviewPanelId == markdownViewerAdvanced",
          "group": "navigation@2"
        }
      ],
      "markdownViewer.exportMenu": [
        {
          "command": "markdownViewer.exportDocx"
        },
        {
          "command": "markdownViewer.exportHtml"
        }
      ],
      "editor/context": [
        {
          "command": "markdownViewer.preview",
          "when": "editorLangId == markdown || editorLangId == mermaid || editorLangId == vega || editorLangId == graphviz || editorLangId == infographic || editorLangId == canvas || editorLangId == drawio || resourceExtname == .md",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "markdownViewer.preview",
          "when": "editorLangId == markdown || editorLangId == mermaid || editorLangId == vega || editorLangId == graphviz || editorLangId == infographic || editorLangId == canvas || editorLangId == drawio || resourceExtname == .md"
        },
        {
          "command": "markdownViewer.previewToSide",
          "when": "editorLangId == markdown || editorLangId == mermaid || editorLangId == vega || editorLangId == graphviz || editorLangId == infographic || editorLangId == canvas || editorLangId == drawio || resourceExtname == .md"
        },
        {
          "command": "markdownViewer.exportDocx",
          "when": "editorLangId == markdown || editorLangId == mermaid || editorLangId == vega || editorLangId == graphviz || editorLangId == infographic || editorLangId == canvas || editorLangId == drawio || resourceExtname == .md"
        },
        {
          "command": "markdownViewer.print",
          "when": "activeWebviewPanelId == markdownViewerAdvanced"
        }
      ]
    },
    "configuration": {
      "title": "Markdown Viewer",
      "properties": {
        "markdownViewer.theme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "github-light",
            "github-dark",
            "academic",
            "minimal"
          ],
          "description": "Theme for the Markdown preview"
        },
        "markdownViewer.fontSize": {
          "type": "number",
          "default": 16,
          "minimum": 10,
          "maximum": 32,
          "description": "Base font size in pixels"
        },
        "markdownViewer.fontFamily": {
          "type": "string",
          "default": "",
          "description": "Font family for the preview (leave empty for default)"
        },
        "markdownViewer.lineNumbers": {
          "type": "boolean",
          "default": true,
          "description": "Show line numbers in code blocks"
        },
        "markdownViewer.scrollSync": {
          "type": "boolean",
          "default": true,
          "description": "Synchronize scrolling between editor and preview"
        },
        "markdownViewer.markdownViewerSettings": {
          "type": "object",
          "default": {},
          "description": "Internal settings storage for Markdown Viewer (managed by the extension)"
        },
        "markdownViewer.selectedTheme": {
          "type": "string",
          "default": "default",
          "description": "Selected theme identifier"
        },
        "markdownViewer.markdownHistory": {
          "type": "array",
          "default": [],
          "description": "Recent file history"
        }
      }
    },
    "keybindings": [
      {
        "command": "markdownViewer.previewToSide",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "editorLangId == markdown || editorLangId == mermaid || editorLangId == vega || editorLangId == graphviz || editorLangId == infographic || resourceExtname == .svg || resourceExtname == .md"
      }
    ]
  },
  "icon": "icons/icon128.png"
}
